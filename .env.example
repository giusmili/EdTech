# OpenAI API key used by the student help chatbot.
OPENAI_API_KEY="sk-..."

# Public production URL used for canonical, Open Graph and Twitter metadata.
NEXT_PUBLIC_SITE_URL="https://example.com"

# Optional: choose the model used by the chatbot.
OPENAI_MODEL="gpt-5"

# Optional: OpenAI-compatible API fallback.
AI_API_KEY=""
AI_API_URL=""
AI_MODEL=""

# Demo login credentials for the local app.
AUTH_USERNAME="demo"
AUTH_PASSWORD="demo"
